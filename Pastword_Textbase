package pastword;

import java.util.*;

public class Pastword {

    public static void main(String[] args) {
        Scanner input = new Scanner (System.in);
        
        HashSet<String> username = new HashSet<>();
        HashSet<String> password = new HashSet<>();
        HashMap<Integer, String> Pastword = new HashMap<>();
        boolean runProgram = true;
        int passwordCounter = 1;
        
        do {
        System.out.print("----MENU----\n1. Create Account\n2. Login Account\nYour Choice:");
        int user_input1 = input.nextInt();
        input.nextLine();
        
        switch (user_input1) {
        
        case 1: //SIGN IN
            System.out.println("----SIGN-IN----");
            System.out.print("Username: ");
            username.add(input.nextLine());
            
            System.out.print("Password: ");
            password.add(input.nextLine());
            
        case 2://LOG-IN
            System.out.println("\n----LOGIN----");
            System.out.print("Enter Username: ");
            String username1 = input.nextLine();
            
            System.out.print("Enter Password: ");
            String password1 = input.nextLine();
            
            if (username.contains(username1) && password.contains(password1)) {
                runProgram = false;
                break;
            
            } else {
                System.out.println("Incorrect Account!!!\n");
                continue;
            }
        
        default:
            System.out.print("Invalid Input!! User the number choice");
            break;
        }
     
        } while (runProgram);
        
            boolean runProgram1 = true;
            do {
                
            
            String[] options = {"Add Password", "Display Password", "Edit Password", "Delete Password", "Exit"};
            int number = 1;
            System.out.println("\n----PASTWORD----");
            for (int i = 0; i < options.length; i++) {
                System.out.println(number + ". " + options[i]);
                number ++;
            }
            System.out.println("Your Choice: ");
            int user_input2 = input.nextInt();
            input.nextLine();
            switch (user_input2) {
            case 1:
                System.out.print("\nEnter Password to store: ");
                String store_password = input.nextLine();
                
                System.out.print("\nPassword Store!!!\n\n----ACCOUNT INFORMATION----\nUsername: " + username + "\nPassword Stored: " + store_password + "\n");
                Pastword.put(passwordCounter, store_password);
                passwordCounter ++;
                break;
            
            case 2:
                System.out.println("\n----STORED PASSWORD----");
                for (int i : Pastword.keySet()) {
                    System.out.print(i + ". " + Pastword.get(i) + "\n");
                }
                break;
            
            case 3:
                for (int i : Pastword.keySet()) {
                    System.out.print(i + ". " + Pastword.get(i) + "\n");
                }
                
                System.out.print("\nSelect what Key you want to change: ");
                int user_key = input.nextInt();
                input.nextLine();
  
                System.out.print("\nEnter New Password: ");
                String new_password = input.nextLine();
                
                Pastword.put(user_key, new_password);
                break;
            
            case 4:
                for (int i : Pastword.keySet()) {
                    System.out.print(i + ". " + Pastword.get(i) + "\n");
                }
                System.out.print("Select what key you want to remove: ");
                int remove_key = input.nextInt();
                input.nextLine();
                
                Pastword.remove(remove_key);
                System.out.println("PASSWORD REMOVED!!!\n");
                
            case 5:
                runProgram1 = false;
                break;
            
            default:
                System.out.println("Invalid Input!!!" );
                break;
            }
            
            } while (runProgram1);
            

    

    } 
    }
